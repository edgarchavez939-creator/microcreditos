APP_NAME="Microcreditos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://TU-SERVICIO.onrender.com
APP_TIMEZONE=America/Bogota

LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- PostgreSQL: pega aquí la cadena de conexión de Neon ---
# Ejemplo Neon: postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/microcreditos?sslmode=require
DATABASE_URL=
DB_CONNECTION=pgsql
DB_SSLMODE=require

# --- Modo prueba: sin Redis ---
CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# --- JWT (genera con: php artisan jwt:secret) ---
JWT_SECRET=
JWT_TTL=15
JWT_REFRESH_TTL=20160

# --- CORS: dominio del frontend en Vercel ---
CORS_ALLOWED_ORIGINS=https://TU-APP.vercel.app

# --- S3 (opcional en pruebas; para subir documentos) ---
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

GOOGLE_MAPS_API_KEY=
THROTTLE_LOGIN=5,1
